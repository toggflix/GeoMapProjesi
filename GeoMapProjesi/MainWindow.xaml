<Window x:Class="GeoMapProjesi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
        mc:Ignorable="d"
        Title="GeoMap Projesi - Ana Kontrol Paneli" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" Foreground="White">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4E4E56"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">
            <StackPanel Margin="20">

                <ComboBox x:Name="CmbLanguage" Width="120" Height="30" HorizontalAlignment="Right" 
                          Background="#333" Foreground="White" BorderThickness="0" 
                          SelectionChanged="CmbLanguage_SelectionChanged" Margin="0,0,0,15">
                    <ComboBox.Resources>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#333"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBoxItem IsSelected="True" Tag="TR" Content="🇹🇷 Türkçe"/>
                    <ComboBoxItem Tag="EN" Content="🇺🇸 English"/>
                </ComboBox>

                <TextBlock x:Name="LblMainHeader" Text="🌍 GeoMap Kontrol" FontSize="22" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,30" HorizontalAlignment="Center"/>

                <TextBlock x:Name="LblToolsTitle" Text="HARİTA ARAÇLARI" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button x:Name="BtnClear" Content="🧹 Temizle" Style="{StaticResource ModernButton}" Width="125" Margin="0,0,10,0" Click="BtnClear_Click"/>
                    <Button x:Name="BtnHistory" Content="📜 Geçmiş" Style="{StaticResource ModernButton}" Width="125" Click="BtnHistory_Click"/>
                </StackPanel>

                <Border Background="#333337" CornerRadius="5" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock x:Name="LblMeasureTitle" Text="📏 MESAFE ÖLÇÜMÜ" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TxtDistance" Text="0.00 km" FontSize="24" FontWeight="Bold" Foreground="#FFD700" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="LblMeasureHint" Text="Haritaya çift tıklayarak nokta ekleyin." FontSize="11" Foreground="#888" Margin="0,5,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="LblAnalyzeTitle" Text="ANALİZ İŞLEMLERİ" FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                <Button x:Name="BtnAnalyze" Content="🚀 BÖLGEYİ ANALİZ ET" Style="{StaticResource ModernButton}" 
                        Background="#007ACC" FontSize="16" Height="50" Click="BtnAnalyze_Click"/>

                <Border Background="#333337" CornerRadius="5" Padding="10" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock x:Name="LblStatusTitle" Text="DURUM BİLGİSİ" FontSize="11" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TxtStatus" Text="Sistem Hazır." FontSize="13" Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="#1E1E1E">
            <gmap:GMapControl x:Name="MainMap" Zoom="13" MaxZoom="20" MinZoom="2" Margin="10"/>

            <Grid x:Name="LoadingOverlay" Background="#AA000000" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="LblLoadingTitle" Text="Görüntü İşleniyor..." FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LblLoadingDesc" Text="Lütfen bekleyiniz, yapay zeka analiz yapıyor." FontSize="16" Foreground="#CCC" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>