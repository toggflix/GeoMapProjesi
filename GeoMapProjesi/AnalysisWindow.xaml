<Window x:Class="GeoMapProjesi.AnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GeoMap - Analysis Dashboard" Height="750" Width="1280"
        WindowStartupLocation="CenterScreen" 
        Background="#1E1E1E" Foreground="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1.2*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock x:Name="LblMainTitle" Text="🌍 GEO-SPATIAL 3D ANALYSIS DASHBOARD" 
                       FontSize="24" FontWeight="Bold" Foreground="#007ACC" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtTarih" Text="..." FontSize="12" Foreground="#888" HorizontalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#252526" CornerRadius="8" Margin="5" Padding="5">
                <StackPanel>
                    <TextBlock x:Name="LblImgOriginal" Text="🛰️ UYDU (RGB)" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center" FontSize="11"/>
                    <Image x:Name="ImgOriginal" Stretch="Uniform"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#252526" CornerRadius="8" Margin="5" Padding="5">
                <StackPanel>
                    <TextBlock x:Name="LblImgResult" Text="🧠 SINIFLANDIRMA" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,5" HorizontalAlignment="Center" FontSize="11"/>
                    <Image x:Name="ImgResult" Stretch="Uniform"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#252526" CornerRadius="8" Margin="5" Padding="5" BorderBrush="#FF4500" BorderThickness="0,0,0,2">
                <StackPanel>
                    <TextBlock x:Name="LblImgDepth" Text="⛰️ 3D TOPOĞRAFYA" FontWeight="Bold" Foreground="#FF4500" Margin="0,0,0,5" HorizontalAlignment="Center" FontSize="11"/>
                    <Image x:Name="ImgDepth" Stretch="Uniform"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#252526" CornerRadius="10" Padding="15" Margin="0,0,10,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="LblStatsTitle" Text="📊 ARAZİ DAĞILIMI" FontWeight="Bold" Margin="0,0,0,10" Foreground="#AAA"/>

                    <Grid Margin="0,0,0,5">
                        <TextBlock x:Name="LblForest" Text="🌲 Orman" FontSize="11"/>
                        <TextBlock x:Name="TxtOrmanYuzde" Text="%0" HorizontalAlignment="Right" FontSize="11" FontWeight="Bold"/>
                    </Grid>
                    <ProgressBar x:Name="PbOrman" Height="6" Background="#333" Foreground="Green" BorderThickness="0" Value="0" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,5">
                        <TextBlock x:Name="LblWater" Text="💧 Su Kütlesi" FontSize="11"/>
                        <TextBlock x:Name="TxtSuYuzde" Text="%0" HorizontalAlignment="Right" FontSize="11" FontWeight="Bold"/>
                    </Grid>
                    <ProgressBar x:Name="PbSu" Height="6" Background="#333" Foreground="#00BFFF" BorderThickness="0" Value="0" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,5">
                        <TextBlock x:Name="LblCity" Text="🏙️ Yerleşim" FontSize="11"/>
                        <TextBlock x:Name="TxtSehirYuzde" Text="%0" HorizontalAlignment="Right" FontSize="11" FontWeight="Bold"/>
                    </Grid>
                    <ProgressBar x:Name="PbSehir" Height="6" Background="#333" Foreground="#FFD700" BorderThickness="0" Value="0" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,5">
                        <TextBlock x:Name="LblAgri" Text="🌾 Tarım" FontSize="11"/>
                        <TextBlock x:Name="TxtTarimYuzde" Text="%0" HorizontalAlignment="Right" FontSize="11" FontWeight="Bold"/>
                    </Grid>
                    <ProgressBar x:Name="PbTarim" Height="6" Background="#333" Foreground="Orange" BorderThickness="0" Value="0" Margin="0,0,0,5"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#252526" CornerRadius="10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="LblReportTitle" Text="🏗️ MİMARİ RAPOR" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,10"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtMimarYorum" Text="..." TextWrapping="Wrap" Foreground="#DDD" FontSize="13" LineHeight="20"/>
                    </ScrollViewer>

                    <Button x:Name="BtnClose" Grid.Row="2" Content="KAPAT" Height="30" Width="100" Background="#333" Foreground="White" 
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,0,0" Click="Button_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>